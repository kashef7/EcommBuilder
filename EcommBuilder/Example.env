# Database Configuration
ConnectionStrings__DefaultConnection="Host=localhost;Port=5433;Database=EcommBuilderDB;Username=postgres;Password=your_password_here"

# Google Authentication Keys
GoogleKeys__ClientId="your_google_client_id.apps.googleusercontent.com"
GoogleKeys__ClientSecret="your_google_client_secret"

# JWT Token Settings
Jwt__Key="your_super_secret_jwt_key_here"
Jwt_Issuer="EcommBuilder"
Jwt_Audience="EcommBuilder"
Jwt_ExpiryDays=30