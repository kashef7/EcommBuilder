# Use the official Node 24 runtime on Alpine Linux
FROM node:24-alpine

# Set the active working directory inside the container
WORKDIR /app

# Copy package management definitions first to leverage layer caching
COPY package*.json ./

# Install project dependencies (Vite, React, etc.) inside the container
RUN npm install

# Copy your React component source code files
COPY . .

# Expose Vite's default local development port
EXPOSE 5173

# Execute the development server with host flags to allow external Nginx proxying
CMD ["npm", "run", "dev", "--", "--host"]